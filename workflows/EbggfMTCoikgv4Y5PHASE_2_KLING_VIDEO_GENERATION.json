        "jsCode": "let parentId;\n\n// Check if the folder was found in \"Search final folder\"\nconst searchItems = $items(\"Search final folder\", 0, 0);\n\nif (searchItems.length > 0 && searchItems[0].json.id) {\n  parentId = searchItems[0].json.id;\n} else {\n  // If not found, use the folder created in \"Create final folder\"\n  const createdItems = $items(\"Create final folder\", 0, 0);\n\n  if (!createdItems.length || !createdItems[0].json.id) {\n    throw new Error(\"Parent folder not found and not created.\");\n  }\n\n  parentId = createdItems[0].json.id;\n}\n\nreturn [\n  {\n    json: {\n      parentFolderId: parentId\n    }\n  }\n];"
