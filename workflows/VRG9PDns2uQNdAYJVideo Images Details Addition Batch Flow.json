        "resource": "image",
        "simplify": false,
        "text": "given the image describe the following in json format\n\n\n\nJSON output only as :\n{\n  \"motion_type\": \"Posing/Action (Choose Posing for standing/looking/twirl/side looks etc; Action for only when holding something or sitting)\",\n  \"gender\": \"Male / Female / Both\",\n  \"num_of_people\": 1,\n  \"shot_type\": \"Extreme Wide / Wide / Mid / Close up / Extreme Close up\",\n  \"shot_angle\": \"Eye level / Top Angle / Low Angle\",\n  \"pose_type\": \"Front / Side / Back\",\n  \"orientation\": \"Sitting / Standing / Walking / Running \",\n\"face_visibile\":\"Yes/ No\",\n  \"clothing_highlevel\": \"Casual / Ethnic / Formals\",\n  \"shot_angle_description\": \"Detailed description of the shot angle.\",\n  \"clothing_description\": \"Detailed description of clothing (approx. 50 words).\",\n  \"background_description\": \"Detailed description of the background (approx. 50 words).\",\n  \"lighting_mood_description\": \"Detailed description of the lighting and mood (approx. 50 words).\",\n  \"action_description\": \"Detailed description of the action in the image (approx. 50 words).\"\n}"
