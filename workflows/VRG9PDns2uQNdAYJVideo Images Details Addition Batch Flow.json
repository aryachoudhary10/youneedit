    {
      "id": "fd33294e-0f8a-4c64-851e-3e8869abb3bc",
      "name": "Merge with parent",
      "parameters": {
        "jsCode": "// Reference the current parent folder item from the Loop node\nconst parentFolder = $('Loop Over Items').item.json;\n\n// Get all 55 items from the files node and map them\nconst files = $('Get files in the folder').all().map(item => {\n  const fileData = item.json;\n  \n  return {\n    id: fileData.id,\n    name: fileData.name,\n    // Construct the direct download link using the file ID\n    file_link: `https://drive.google.com/uc?export=download&id=${fileData.id}`\n  };\n});\n\n// Create the single final object structure\nreturn {\n  parent_id: parentFolder.id,\n  parent_name: parentFolder.name,\n  file_list: files\n};"
      },
      "position": [
        16,
        -192
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "23bb4d08-e6e9-4bc5-b347-e0c9dda5eed9",
      "name": "Restructure Data",
      "parameters": {
        "jsCode": "// --- CONFIGURATION: Set your folder names here ---\nconst FOLDER_MOTIONS = 'Motion Bank';\nconst FOLDER_THUMBS = 'Motion Bank Thumbnails';\nconst FOLDER_ORIGINALS = 'Video Downloads';\n\n// 1. Get all input items\nconst allData = $input.all().map(item => item.json);\n\n// 2. Identify the specific datasets using the variables defined above\nconst motionBank = allData.find(d => d.parent_name === FOLDER_MOTIONS) || { file_list: [] };\nconst thumbnails = allData.find(d => d.parent_name === FOLDER_THUMBS) || { file_list: [] };\nconst videoDownloads = allData.find(d => d.parent_name === FOLDER_ORIGINALS) || { file_list: [] };\n\n// Helper function to remove extension\nconst removeExt = (filename) => filename.replace(/\\.[^/.]+$/, \"\");\n\n// 3. Map through the Motion Bank files to create the final consolidated JSON\nconst finalOutput = motionBank.file_list.map(file => {\n  const motionId = removeExt(file.name);\n  \n  // Logic for Thumbnail: Match filename (no ext) exactly with MotionId\n  const thumbMatch = thumbnails.file_list.find(t => removeExt(t.name) === motionId);\n  \n  // Logic for Original Video: Split MotionId on '_' and match the first part\n  const originalPrefix = motionId.split('_')[0];\n  const originalMatch = videoDownloads.file_list.find(v => removeExt(v.name) === originalPrefix);\n\n  return {\n    \"MotionID\": motionId,\n    \"Motion Video Link\": file.file_link,\n    \"Motion Thumbnail Link\": thumbMatch ? thumbMatch.file_link : \"No Thumbnail Found\",\n    \"Original Video Link\": originalMatch ? originalMatch.file_link : \"No Original Found\"\n  };\n});\n\nreturn finalOutput;"
      },
