    {
      "id": "465b8f7a-a293-4b28-abaf-779e42bc04a1",
      "name": "Parse AI output Data",
      "parameters": {
        "jsCode": "// 1. Reference the nodes by their specific names\nconst aiNode = $('Analyze an image').item;\nconst loopNode = $('Loop Over each row').item;\n\n// 2. Safety check: Ensure the nodes actually have data\nif (!aiNode || !loopNode) {\n  return {\n    json: {\n      error: \"Could not find data from 'Analyze an image' or 'Loop Over each row' nodes.\"\n    }\n  };\n}\n\nconst rawText = aiNode.json.candidates[0].content.parts[0].text;\nconst motionId = loopNode.json.MotionID;\n\n// 3. Clean and Extract JSON using Regex (handles extra conversational text)\nconst jsonMatch = rawText.match(/```json\\n?([\\s\\S]*?)\\n?```/) || rawText.match(/{[\\s\\S]*}/);\nconst cleanJsonString = jsonMatch ? (jsonMatch[1] || jsonMatch[0]) : rawText;\n\ntry {\n  // 4. Parse the string into a real JSON object\n  const parsedData = JSON.parse(cleanJsonString.trim());\n\n  // 5. Return the merged result wrapped in the required 'json' key\n  return {\n    json: {\n      MotionID: motionId,\n      ...parsedData\n    }\n  };\n} catch (e) {\n  // 6. If parsing fails, return the error safely inside the 'json' key\n  return {\n    json: {\n      MotionID: motionId,\n      status: \"error\",\n      error_message: e.message,\n      raw_ai_output: rawText\n    }\n  };\n}"
      },
