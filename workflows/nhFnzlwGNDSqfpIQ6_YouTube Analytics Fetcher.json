      "id": "040d609f-c937-431a-afdb-bc06e8fdd9bd",
      "name": "Save Video & Metrics",
      "parameters": {
        "operation": "executeQuery",
        "options": {},
        "query": "=-- Insert content\nINSERT INTO content (content_id, account_id, platform, content_type, title, hook, idea, url, posted_at, duration_sec, metadata)\nVALUES (\n  '{{ $json.content_id }}',\n  '{{ $json.account_id }}',\n  '{{ $json.platform }}',\n  '{{ $json.content_type }}',\n  '{{ $json.title }}',\n  '{{ $json.hook }}',\n  '{{ $json.idea }}',\n  '{{ $json.url }}',\n  '{{ $json.posted_at }}',\n  {{ $json.duration_sec }},\n  '{{ JSON.stringify($json.metadata) }}'\n)\nON CONFLICT (content_id) DO UPDATE SET\n  title = EXCLUDED.title,\n  duration_sec = EXCLUDED.duration_sec,\n  metadata = EXCLUDED.metadata;\n\n-- Insert metrics\nINSERT INTO metrics_daily (content_id, account_id, date, views, likes, comments, shares, saves)\nVALUES (\n  '{{ $json.content_id }}',\n  '{{ $json.account_id }}',\n  '{{ $json.date }}',\n  {{ $json.views }},\n  {{ $json.likes }},\n  {{ $json.comments }},\n  {{ $json.shares }},\n  {{ $json.saves }}\n)\nON CONFLICT (content_id, date) DO UPDATE SET\n  views = EXCLUDED.views,\n  likes = EXCLUDED.likes,\n  comments = EXCLUDED.comments,\n  created_at = NOW();"
      },
      "position": [
        992,
        464
      ],
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2
