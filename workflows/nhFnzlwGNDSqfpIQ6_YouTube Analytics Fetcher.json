    {
      "id": "6372d651-feed-443e-abe0-7324c01110bf",
      "name": "Transform Channel Data",
      "parameters": {
        "jsCode": "// Get the input (which is the whole array of items)\nconst items = $input.all();\n\n// We map over every input item, then map over every channel in 'items'\nreturn items.flatMap(item => {\n  return item.json.items.map(channel => {\n    return {\n      json: {\n        account_id: channel.id,\n        username: channel.snippet.title,\n        display_name: channel.snippet.customUrl || channel.snippet.title,\n        followers_count: parseInt(channel.statistics?.subscriberCount || 0),\n        uploads_playlist_id: channel.contentDetails?.relatedPlaylists?.uploads,\n        metadata: {\n          description: channel.snippet.description,\n          thumbnail: channel.snippet.thumbnails?.high?.url,\n          total_videos: parseInt(channel.statistics?.videoCount || 0),\n          total_views: parseInt(channel.statistics?.viewCount || 0)\n        }\n      }\n    };\n  });\n});"
      },
      "position": [
        -272,
        464
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "credentials": {
        "postgres": {
          "id": "I73Fy2WxZHWGX3DC",
          "name": "Postgres account"
        }
      },
      "id": "09b54c73-fe58-4ae8-bd50-fd4a66a152b2",
      "name": "Save Channel Info",
      "parameters": {
        "operation": "executeQuery",
        "options": {},
        "query": "=INSERT INTO accounts (account_id, platform, username, display_name, followers_count, metadata, updated_at)\nVALUES (\n  '{{ $json.account_id }}',\n  'youtube',\n  '{{ $json.username }}',\n  '{{ $json.display_name }}',\n  {{ $json.followers_count }},\n  '{{ JSON.stringify($json.metadata) }}',\n  NOW()\n)\nON CONFLICT (account_id) DO UPDATE SET\n  username = EXCLUDED.username,\n  display_name = EXCLUDED.display_name,\n  followers_count = EXCLUDED.followers_count,\n  metadata = EXCLUDED.metadata,\n  updated_at = NOW()\nRETURNING *;"
      },
