    {
      "id": "c3114e61-d093-4aa1-ada0-3b7b060b3bf7",
      "name": "Transform Video Data",
      "parameters": {
        "jsCode": "// In \"Run Once for Each Item\" mode, use $input.item.json directly\n// n8n automatically gives you the current item - no need for .first() or .all()\nconst apiResponse = $input.item.json;\n\n// Check if we have valid API response\nif (!apiResponse || !apiResponse.items || apiResponse.items.length === 0) {\n  throw new Error('No video data found in API response');\n}\n\nconst videoData = apiResponse.items[0];\n\n// Get account ID from the workflow context\nconst accountId = $('Get YouTube Accounts').item.json.account_id;\n\n// Parse ISO 8601 duration (PT15M30S -> 930 seconds)\nconst parseDuration = (duration) => {\n  if (!duration) return 0;\n  const match = duration.match(/PT(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?/);\n  if (!match) return 0;\n  const hours = parseInt(match[1] || 0);\n  const minutes = parseInt(match[2] || 0);\n  const seconds = parseInt(match[3] || 0);\n  return hours * 3600 + minutes * 60 + seconds;\n};\n\n// Extract title and description\nconst title = videoData.snippet.title || 'Untitled';\nconst description = videoData.snippet.description || '';\nconst lines = description.split('\\n').filter(line => line.trim());\nconst hook = title;\nconst idea = lines.slice(0, 3).join(' ').substring(0, 500);\n\n// Determine content type based on duration\nconst duration = parseDuration(videoData.contentDetails.duration);\nlet contentType = 'video';\nif (duration > 0 && duration <= 60) contentType = 'short';\n\nreturn {\n  // Content data\n  content_id: videoData.id,\n  account_id: accountId,\n  platform: 'youtube',\n  content_type: contentType,\n  title: title,\n  hook: hook,\n  idea: idea,\n  url: `https://www.youtube.com/watch?v=${videoData.id}`,\n  posted_at: videoData.snippet.publishedAt,\n  duration_sec: duration,\n  metadata: {\n    thumbnail: videoData.snippet.thumbnails?.high?.url || videoData.snippet.thumbnails?.default?.url,\n    tags: videoData.snippet.tags || [],\n    category_id: videoData.snippet.categoryId\n  },\n  \n  // Metrics data\n  date: new Date().toISOString().split('T')[0],\n  views: parseInt(videoData.statistics.viewCount || 0),\n  likes: parseInt(videoData.statistics.likeCount || 0),\n  comments: parseInt(videoData.statistics.commentCount || 0),\n  shares: 0, // YouTube API doesn't provide shares directly\n  saves: 0\n};",
        "mode": "runOnceForEachItem"
      },
      "position": [
        800,
        464
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "credentials": {
        "postgres": {
