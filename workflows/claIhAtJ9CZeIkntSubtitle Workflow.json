      {
        "id": "d7c0bae1-4cac-4d70-a5b1-f91ae721abbb",
        "name": "Create Json with id name and transcript1",
        "parameters": {
          "jsCode": "// Helper function to convert seconds (float) to HH:MM:SS,mmm\nfunction formatTime(totalSeconds) {\n    if (totalSeconds === undefined || totalSeconds === null) return \"00:00:00,000\";\n    \n    const hours = Math.floor(totalSeconds / 3600);\n    const minutes = Math.floor((totalSeconds % 3600) / 60);\n    const seconds = Math.floor(totalSeconds % 60);\n    const milliseconds = Math.floor((totalSeconds % 1) * 1000);\n\n    const h = hours.toString().padStart(2, '0');\n    const m = minutes.toString().padStart(2, '0');\n    const s = seconds.toString().padStart(2, '0');\n    const ms = milliseconds.toString().padStart(3, '0');\n\n    // Returns format HH:MM:SS,mmm\n    return `${h}:${m}:${s},${ms}`;\n}\n\nconst results = [];\n\n// Loop through all incoming items\nfor (const item of $input.all()) {\n    const data = item.json;\n    \n    // 1. Initialize the new structure with retained ID and Name\n    const output = {\n        id: data.id || \"\",\n        name: data.name || \"\",\n        transcript: []\n    };\n\n    const segments = data.segments || [];\n    const allWords = data.words || [];\n\n    // 2. Process each segment and add to the transcript list\n    for (const segment of segments) {\n        const sentenceObj = {\n            sentence: segment.text.trim(),\n            start: formatTime(segment.start),\n            end: formatTime(segment.end),\n            words: []\n        };\n\n        // Find words belonging to this segment\n        let segmentWords = [];\n        if (segment.words && segment.words.length > 0) {\n            segmentWords = segment.words;\n        } else {\n            // Fallback: filter words by time if they aren't nested\n            segmentWords = allWords.filter(w => \n                w.start >= segment.start - 0.05 && w.end <= segment.end + 0.05\n            );\n        }\n\n        // Map words to the desired format\n        sentenceObj.words = segmentWords.map(w => ({\n            text: w.word.trim(),\n            start: formatTime(w.start),\n            end: formatTime(w.end)\n        }));\n\n        output.transcript.push(sentenceObj);\n    }\n\n    results.push({ json: output });\n}\n\nreturn results;"
        },
