        "jsCode": "// 1. Extract the raw text from the input JSON structure\nconst rawText = $json.content.parts[0].text;\n\n// 2. Clean the string: Remove leading/trailing markdown fences (```json ... ```)\nconst jsonString = rawText.replace(/^```json\\s*/, '').replace(/\\s*```$/, '').trim();\n\nlet parsedData;\ntry {\n  parsedData = JSON.parse(jsonString);\n} catch (e) {\n  // Return an error item if JSON parsing fails\n  return { 'error': 'Failed to parse internal JSON', 'details': e.message };\n}\n\n// 3. Define your new Global Configuration\nconst newGlobalSettings = {\n  \"normalFont\": \"Poppins-Bold\",\n  \"highlightFont\": \"Poppins-BoldItalic\",\n  \"normalColor\": \"#FFFFFF\",\n  \"highlightColor\": \"#FFE733\",\n  \"normalFontSize\": 120,\n  \"highlightFontSize\": 120,\n  \"highlightUppercase\": true,\n  \"normalUppercase\": false,\n  \"animationPossibilities\": [\"popIn\", \"blurFade\", \"slideReveal\"],\n  \"animation\": \"slideReveal\",\n  \"slideReveal\": {\n    \"normalDirection\": \"bottom\",\n    \"highlightDirection\": \"sides\"\n  },\n  \"animateSequence\": {\n    \"enabled\": true,\n    \"sequence\": [\"popIn\", \"blurFade\", \"slideReveal\"],\n    /**\n     *\"mode Can be \"cycle\", \"random\", or a pattern like '1,2,1,3'\n     */\n    \n    \"mode\": \"random\"\n  },\n  \"shadow\": {\n    \"enabled\": true,\n    \"color\": \"#000000\",\n    \"opacity\": 80,\n    \"direction\": 0,\n    \"distance\": 10,\n    \"size\": 20\n  },\n  \"normalStyle\": {\n    \"stroke\": false,\n    \"strokeWidth\": 3,\n    \"glow\": false,\n    \"glowThreshold\": 30,\n    \"glowRadius\": 40,\n    \"glowIntensity\": 1.8\n  },\n  \"highlightStyle\": {\n    \"stroke\": true,\n    \"strokeWidth\": 3,\n    \"glow\": true,\n    \"glowThreshold\": 30,\n    \"glowRadius\": 40,\n    \"glowIntensity\": 1.8\n  }\n};\n\n// 4. Overwrite the global key with the new settings\nparsedData.global = newGlobalSettings;\n\n// 5. Return the modified object\nreturn parsedData;",
        "mode": "runOnceForEachItem"
