    {
      "id": "d602279f-174c-46ab-a50c-30f84ab767a2",
      "name": "Build Upload Context",
      "parameters": {
        "jsCode": "\nconst d = $input.first().json;\nlet accountsArr;\ntry {\n  accountsArr = typeof d.accounts === 'string' ? JSON.parse(d.accounts) : d.accounts;\n} catch(e) {\n  accountsArr = [d.accounts];\n}\n\nreturn accountsArr.map(account => ({\n  json: {\n    source:        d.source,\n    source_id:     d.source_id,\n    account:       account,\n    reel_url:      d.reel_url,\n    cover_url:     d.cover_url,\n    caption:       d.final_caption,\n    title:         d.title\n  }\n}));\n"
      },
      "position": [
        1648,
        176
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "cad59168-1e03-4cab-8e10-155493e364e6",
      "name": "Detect Platform",
      "parameters": {
        "jsCode": "\nconst account = $json.account.toLowerCase();\nlet platform = 'unknown';\nif (account.includes('instagram')) platform = 'instagram';\nelse if (account.includes('youtube'))  platform = 'youtube';\nelse if (account.includes('linkedin')) platform = 'linkedin';\nreturn [{ json: { ...$json, platform } }];\n"
      },
      "position": [
        1952,
        176
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
