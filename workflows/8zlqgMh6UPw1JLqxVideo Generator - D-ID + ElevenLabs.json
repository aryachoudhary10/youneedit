    {
      "id": "d4bf3823-5038-4e7d-be8f-9ef8764cc12d",
      "name": "Prepare Metadata Filename",
      "notes": "Embed all IDs in filename for tracking",
      "parameters": {
        "jsCode": "// Generate filename with metadata\nconst scriptData = $('Get Approved Scripts').item.json;\n\nconst filename = `script_${scriptData.script_id}_idea_${scriptData.idea_id}_hook_${scriptData.hook_variant_id}_transcript_${scriptData.transcript_id}_source_${scriptData.source_reel_id}.mp4`;\n\nreturn {\n  filename: filename,\n  script_id: scriptData.script_id,\n  idea_id: scriptData.idea_id,\n  hook_variant_id: scriptData.hook_variant_id,\n  transcript_id: scriptData.transcript_id,\n  source_reel_id: scriptData.source_reel_id,\n  video_binary: $input.first().binary\n};"
      },
