      "id": "36097810-e0be-4fe5-b92c-4b1851e3b561",
      "name": "Save to generated_videos",
      "parameters": {
        "operation": "executeQuery",
        "options": {},
        "query": "=INSERT INTO generated_videos (\n  video_id,\n  script_id,\n  video_url,\n  thumbnail_url,\n  duration_sec,\n  status,\n  render_metadata,\n  created_at\n)\nVALUES (\n  '{{ $crypto.randomUUID() }}',\n  '{{ $('Get Approved Scripts').item.json.script_id }}',\n  '{{ $json.webViewLink }}',\n  '{{ $json.thumbnailLink }}',\n  {{ $('Get Approved Scripts').item.json.duration_sec }},\n  'completed',\n  '{{ JSON.stringify({\n    d_id_talk_id: $('D-ID - Create Talking Avatar').item.json.id,\n    google_drive_id: $json.id,\n    filename: $('Prepare Metadata Filename').item.json.filename\n  }) }}',\n  NOW()\n)\nRETURNING video_id;"
      },
