    {
      "id": "105a6129-72dc-4d56-b44c-bb63b70b4f89",
      "name": "Upload Audio to Temporary URL",
      "notes": "Upload audio to publicly accessible URL for D-ID",
      "parameters": {
        "jsCode": "// Upload audio to temporary accessible URL\n// Options:\n// 1. Upload to Cloudinary/S3\n// 2. Use n8n's built-in file sharing\n// 3. Use a temporary file service\n\nconst audioData = $input.first().binary.data;\n\n// For now, we'll use a placeholder\n// You'll need to implement actual file upload\n// Example with Cloudinary:\n\n// const FormData = require('form-data');\n// const form = new FormData();\n// form.append('file', audioData);\n// form.append('upload_preset', 'your_preset');\n\n// const response = await fetch('https://api.cloudinary.com/v1_1/YOUR_CLOUD/upload', {\n//   method: 'POST',\n//   body: form\n// });\n\n// const data = await response.json();\n\nreturn {\n  audio_url: 'YOUR_TEMPORARY_AUDIO_URL', // Replace with actual upload\n  script_id: $('Get Approved Scripts').item.json.script_id\n};"
      },
