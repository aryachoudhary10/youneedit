  "nodes": [
    {
      "id": "1f29c4ee-0cb5-494f-b36f-48d004fcafe1",
      "name": "Every Hour",
      "notes": "Check for approved scripts every hour",
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours"
            }
          ]
        }
      },
      "position": [
        -3200,
        208
      ],
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1
    },
    {
      "id": "27906ea9-20e1-4b18-bd45-e21774aacb79",
      "name": "Get Approved Scripts",
      "parameters": {
        "operation": "executeQuery",
        "options": {},
        "query": "-- Get approved scripts that don't have videos yet\nSELECT \n  s.script_id,\n  s.idea_id,\n  s.hook_variant_id,\n  s.transcript_id,\n  s.script_text,\n  s.scenes,\n  s.duration_sec,\n  i.idea_text,\n  hv.hook_text,\n  t.transcript_text,\n  sr.source_reel_id,\n  c.niche,\n  c.username as source_creator\nFROM scripts s\nJOIN ideas i ON s.idea_id = i.idea_id\nLEFT JOIN hook_variants hv ON s.hook_variant_id = hv.hook_variant_id\nLEFT JOIN transcripts t ON s.transcript_id = t.transcript_id\nLEFT JOIN source_reels sr ON t.source_reel_id = sr.source_reel_id\nLEFT JOIN creators c ON sr.creator_id = c.creator_id\nWHERE s.status = 'approved'\n  AND NOT EXISTS (\n    SELECT 1 FROM generated_videos gv \n    WHERE gv.script_id = s.script_id\n  )\nORDER BY s.created_at ASC\nLIMIT 3;"
      },
      "position": [
        -3008,
        208
      ],
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2
    },
    {
      "id": "2579f2a5-6a97-4a5b-ba41-bcb4e9c58f69",
      "name": "Process One Script",
      "parameters": {
        "options": {}
      },
      "position": [
        -2800,
        208
      ],
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3
    },
    {
      "id": "714307c0-996f-4fd5-a675-e088ff8ddf96",
      "name": "ElevenLabs - Generate Voice",
      "notes": "Generate AI voiceover from script",
      "parameters": {
        "authentication": "genericCredentialType",
        "bodyParameters": {
          "parameters": [
            {
              "name": "text",
              "value": "={{ $json.script_text }}"
            },
            {
              "name": "model_id",
              "value": "eleven_multilingual_v2"
            },
            {
              "name": "voice_settings",
              "value": "={{ { stability: 0.5, similarity_boost: 0.75, style: 0.5, use_speaker_boost: true } }}"
            }
          ]
        },
        "genericAuthType": "httpHeaderAuth",
        "headerParameters": {
          "parameters": [
            {
              "name": "xi-api-key",
              "value": "={{ $credentials.elevenLabsApi.apiKey }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "method": "POST",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        },
        "sendBody": true,
        "sendHeaders": true,
        "url": "https://api.elevenlabs.io/v1/text-to-speech/YOUR_VOICE_ID"
      },
      "position": [
        -2608,
        208
      ],
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4
    },
    {
