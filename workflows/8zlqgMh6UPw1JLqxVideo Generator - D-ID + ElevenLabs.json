          ]
        },
        "jsonBody": "={\n  \"script\": {\n    \"type\": \"audio\",\n    \"audio_url\": \"{{ $('Upload Audio to Temporary URL').item.json.audio_url }}\"\n  },\n  \"source_url\": \"https://create-images-results.d-id.com/DefaultPresenters/Noelle_f/image.jpeg\",\n  \"config\": {\n    \"fluent\": true,\n    \"pad_audio\": 0,\n    \"driver_expressions\": {\n      \"expressions\": [\n        {\n          \"expression\": \"happy\",\n          \"start_frame\": 0,\n          \"intensity\": 0.7\n        }\n      ]\n    },\n    \"result_format\": \"mp4\"\n  }\n}",
        "method": "POST",
        "options": {},
        "sendBody": true,
